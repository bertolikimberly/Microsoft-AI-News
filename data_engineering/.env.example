# Copy to .env and fill in real values.
# .env is gitignored — never commit credentials.

# ─── Database ────────────────────────────────────────────────────────────────
# psycopg3 connection string.
# Local Docker:  postgresql+psycopg://mai:mai@localhost:5432/mai_news
# Azure / Neon:  postgresql+psycopg://<user>:<pass>@<host>:5432/<db>?sslmode=require
DATABASE_URL=postgresql+psycopg://mai:mai@localhost:5432/mai_news

# ─── Embedding model ─────────────────────────────────────────────────────────
# Must produce 384-dim vectors to match the articles.embedding column.
# Changing this requires a full re-embed of the articles table.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Sources registry ────────────────────────────────────────────────────────
# Absolute path to sources.json.  Defaults to <repo_root>/sources.json.
# SOURCES_JSON_PATH=
