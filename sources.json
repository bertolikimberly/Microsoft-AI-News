      },
      "standard": {
        "interval_min": 360,
        "description": "Regular tech, policy, and regional news — checked every 6 hours"
      },
      "daily": {
        "interval_min": 1440,
        "description": "Low-volume official/government/research sources — checked once per day"
      }
    },
    "source_types": {
      "primary": "Official government, regulatory body, or company blog — cite with high confidence in RAG, ground regulatory claims directly to official text",
      "secondary": "Journalistic / editorial source",
      "aggregator": "Multi-source aggregator — parameterize query in rss_url"
    },
    "notes": [
      "RSS URLs marked with [VERIFY] need confirmation before going to production",
      "Sources with content_quality=excerpts require Crawl4AI/newspaper3k full-body fetch",
      "The Local (ids 16-24) should be one feedparser integration looping over the URL list, populating source_region per feed",
      "Government primary sources (eu_parliament, edpb, eu_commission_press) must be tagged source_type=primary in the DB so the LLM can cite them with higher confidence",
      "arXiv feeds are high-volume — apply relevance filtering before embedding"
    ]
  },
