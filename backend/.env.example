# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# ─── Runtime ─────────────────────────────────────────────
# "dev" enables convenience features (dev-login endpoint, relaxed CORS).
# Must be "prod" in production. Anything else is treated as dev.
ENV=dev

# ─── Database ────────────────────────────────────────────
# Local dev: docker-compose Postgres at the repo root.
#   `docker compose up -d postgres`  then use the URL below.
# The image is pgvector/pgvector:pg16, so the `vector` extension ships
# pre-installed and the app's startup CREATE EXTENSION succeeds.
DATABASE_URL=postgresql+psycopg://mai:mai@localhost:5432/mai_news

# Azure Postgres Flexible Server (prod):
#   DATABASE_URL=postgresql+psycopg://<user>:<pass>@<host>.postgres.database.azure.com:5432/<db>?sslmode=require
# Reminder — before the app's CREATE EXTENSION call will succeed,
# add `vector` to the server-level `azure.extensions` parameter
# (Portal → Server parameters → azure.extensions → save → reboots in seconds).
#
# Neon (alternative prod): vector is pre-enabled, no setup.
#   DATABASE_URL=postgresql+psycopg://<user>:<pass>@<host>.neon.tech/<db>?sslmode=require

# ─── Embeddings ──────────────────────────────────────────
# Both must match: sentence-transformers `all-MiniLM-L6-v2` outputs 384 dims.
# Change them together or pgvector will reject mismatched-dim writes.
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ─── JWT (our own session token, not Entra's) ────────────
# HS256 + a symmetric secret. In production, the secret is set in the
# hosting platform's env-var UI (Render dashboard) — never committed.
# Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=dev-only-change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ISSUER=tech-intel-news
JWT_AUDIENCE=tech-intel-news-api
JWT_TTL_MINUTES=30

# ─── Microsoft Entra ID OAuth ────────────────────────────
# Populate from the App Registration in your free Entra tenant.
# No Azure subscription or credit card needed — see setup steps below.
#
# One-time setup (~10 minutes, free):
#   1. Sign in to https://entra.microsoft.com with a personal Microsoft account.
#   2. Top-right account menu → Manage tenants → Create →
#      Microsoft Entra ID → name it (e.g. "MS AI News Dev") → finish.
#   3. Switch into the new tenant.
#   4. App registrations → New registration:
#        - Name: Microsoft AI News (dev)
#        - Supported accounts: single tenant
#        - Redirect URI: Web → http://localhost:8000/api/v1/auth/callback
#   5. From the app's Overview page, copy:
#        - Application (client) ID  → ENTRA_CLIENT_ID below
#        - Directory (tenant) ID    → ENTRA_TENANT_ID below
#   6. Certificates & secrets → New client secret →
#        copy the secret VALUE immediately (only shown once) → ENTRA_CLIENT_SECRET.
#   7. Users → New user → Create new user → add 2-3 fake employees
#        (e.g. alice.eng@<your-tenant>.onmicrosoft.com) for testing.
#
# Leave these blank to disable the Entra flow and use /auth/dev-login.
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# ─── Frontend ────────────────────────────────────────────
# Where /auth/callback redirects the browser back to after login.
# Defaults to Vite's dev server port; change if your frontend runs elsewhere.
# In prod: the Vercel deployment URL, e.g. https://tech-intel-news.vercel.app
FRONTEND_URL=http://localhost:3000

# ─── CORS allowed origins (prod only) ────────────────────
# Comma-separated list of origins the API will accept cross-origin
# requests from. Dev mode ignores this and uses a fixed localhost list.
# In prod, set this to the Vercel deployment URL — same value as FRONTEND_URL.
#   ALLOWED_ORIGINS=https://tech-intel-news.vercel.app
ALLOWED_ORIGINS=

# ─── LLM (OpenAI direct) ─────────────────────────────────
# Pay-as-you-go. Cost-per-user analysis in the report uses public pricing.
# Set a hard monthly $-cap on https://platform.openai.com/account/limits
# so accidents are bounded.
# Leave blank to disable LLM calls (digest worker + chat service will fail
# loudly when invoked — by design, so we don't ship dead code).
OPENAI_API_KEY=
OPENAI_MODEL_SMALL=gpt-4o-mini
OPENAI_MODEL_LARGE=gpt-4o

# ─── Anthropic (llm_engineering pipeline) ────────────────
# LLM_PROVIDER defaults to "openai" — only fill in ANTHROPIC_API_KEY if you
# want to override to Claude (set LLM_PROVIDER=anthropic in that case).
# Without a key the pipeline falls back to the OpenAI path automatically.
ANTHROPIC_API_KEY=

# ─── Email (Azure Communication Services) ────────────────
# Connection string from the ACS resource (Portal → Communication Services
# → Keys → Primary connection string).
# Sender address is the Azure Managed Domain address provisioned by Bicep
# (e.g. DoNotReply@<random>.azurecomm.net).
ACS_CONNECTION_STRING=
ACS_SENDER_ADDRESS=

# ─── Internal worker auth ────────────────────────────────
# Shared secret used by /api/v1/internal/* endpoints — invoked by the
# GitHub Actions cron workflow (.github/workflows/digest-cron.yml) to
# trigger the digest worker, not by end users. Generate a long random
# string and store it in:
#   - this .env locally
#   - the matching GitHub repo secret (Settings → Secrets → Actions →
#     WORKER_SHARED_SECRET)
#   - your deploy environment variables (Render, Fly, etc.)
# Leave blank to disable the internal endpoints (they return 503).
WORKER_SHARED_SECRET=
